{
    "name": "stripe/address-taxid-demo",
    "description": "Stripe Address and Tax ID Elements Demo",
    "type": "project",
    "require": {
        "php": "^8.2",
        "stripe/stripe-php": "^13.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "scripts": {
        "serve": "php -S localhost:8000",
        "lint": [
            "@php -l index.php",
            "@php -l create-payment-intent.php"
        ]
    }
}
